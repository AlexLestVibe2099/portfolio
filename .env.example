# Публичный URL сайта (для Open Graph и canonical)
VITE_SITE_URL=https://your-portfolio.vercel.app

# ID счётчика Яндекс.Метрики (оставьте пустым, чтобы отключить)
VITE_YM_COUNTER_ID=

# Серверные переменные для api/lead.js (Vercel):
# 1) Создайте бота через @BotFather -> /newbot и получите токен.
# 2) Напишите боту /start, затем откройте:
#    https://api.telegram.org/bot<TOKEN>/getUpdates
# 3) Возьмите значение chat.id и подставьте ниже.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
